<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Add permission for biometric use -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" /> <!-- add fingerprint for older devices -->
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <uses-feature
        android:name="android.hardware.fingerprint"
        android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WarehouseInventoryManagement"
        tools:targetApi="31">

        <!--Make LockScreen the starting activity-->
        <activity
            android:name=".Lockscreen"
            android:label="Mobile2App Inventory"
            android:exported="true"
            android:theme="@style/Theme.WarehouseInventoryManagement">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!--Add MainActivity-->
        <activity android:name=".MainActivity"
            android:exported="false"/>
    </application>

</manifest>